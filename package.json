{
  "name": "rx-fhir",
  "version": "1.0.41",
  "description": "℞ + FHIR = RxFHIR — 基於 TW Core 電子處方箋 Profile 的桌面應用程式",
  "author": "Yu-Ru Pan <ruru@swift.moe>",
  "type": "module",
  "main": "./out/main/index.cjs",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "build": "node scripts/run-electron-vite.mjs build",
    "start": "node scripts/run-electron-vite.mjs preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "npm run build && playwright test",
    "test:ui:headed": "npm run build && playwright test --headed",
    "test:ui:report": "playwright show-report",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "typecheck": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false",
    "a11y:check": "node scripts/a11y-smoke-check.mjs",
    "cdp:eval": "node scripts/electron-cdp-eval.mjs",
    "ux:electron:smoke": "node scripts/electron-ux-smoke.mjs",
    "ux:electron:verify": "node scripts/electron-ux-verify.mjs",
    "release": "node scripts/release.js",
    "postinstall": "node scripts/patch-electron-dev.js",
    "patch-dev": "node scripts/patch-electron-dev.js"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@fontsource/noto-sans-tc": "^5.2.9",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "i18next": "^26.0.2",
    "lucide-react": "^0.454.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^17.0.1",
    "react-json-view-lite": "^1.5.0",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.59.1",
    "@types/fhir": "^0.0.41",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.6",
    "vitest": "^2.1.9"
  }
}
